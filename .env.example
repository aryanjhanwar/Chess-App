# App Configuration
VITE_APP_NAME=ChessApp

# PeerJS / Multiplayer (optional — defaults to public PeerJS server)
# VITE_PEER_SERVER_HOST=
# VITE_PEER_SERVER_PORT=

# TURN Server Credentials (optional — defaults to openrelay public server)
# VITE_TURN_URL=turn:openrelay.metered.ca:80
# VITE_TURN_USERNAME=openrelayproject
# VITE_TURN_CREDENTIAL=openrelayproject

# CDN / Asset Base URL (optional — defaults to vite BASE_URL)
# VITE_ASSET_BASE_URL=
