# Required environment variables — copy to .env and fill in real values

# ─── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Database ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/chessapp?retryWrites=true&w=majority

# ─── Authentication ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
JWT_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────
# Frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5173
